{
  "comments": {
    "lineComment": "//",
    "blockComment": ["{{--", "--}}"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}", "notIn": ["string", "comment"] },
    { "open": "[", "close": "]", "notIn": ["string", "comment"] },
    { "open": "(", "close": ")", "notIn": ["string", "comment"] },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "`", "close": "`", "notIn": ["string", "comment"] },
    { "open": "<!--", "close": "-->", "notIn": ["string", "comment"] },
    { "open": "{{--", "close": "--}}", "notIn": ["string", "comment"] },
    { "open": "{{", "close": "}}", "notIn": ["string", "comment"] },
    { "open": "{!!", "close": "!!}", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"],
    ["<", ">"]
  ],
  "colorizedBracketPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(@(if|unless|foreach|forelse|for|while|switch|auth|guest|can|cannot|canany|section|component|slot|push|prepend|once|php|isset|empty|env|production|verbatim|error|setup|register|script|await|block|comment)\\b|<!--\\s*#?region\\b)",
      "end": "^\\s*(@(endif|endunless|endforeach|endforelse|endfor|endwhile|endswitch|endauth|endguest|endcan|endcannot|endcanany|endsection|endcomponent|endslot|endpush|endprepend|endonce|endphp|endisset|endempty|endenv|endproduction|endverbatim|enderror|endsetup|endregister|endscript|endawait|endblock|endcomment)\\b|<!--\\s*#?endregion\\b)"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "(?x)\n  (<(?!area|base|br|col|embed|hr|img|input|keygen|link|menuitem|meta|param|source|track|wbr)([a-zA-Z][a-zA-Z0-9-]*)\\b[^/>]*>(?!.*</\\2\\s*>)\\s*$)\n  |(<(?:blade|script|style)\\b[^>]*>\\s*$)\n  |(^\\s*@(if|unless|foreach|forelse|for|while|switch|auth|guest|can|cannot|canany|section|component|slot|push|prepend|once|php|isset|empty|env|production|verbatim|error|setup|register|script|await|block|comment)\\b)\n  |(\\{[^}]*$)\n  |(\\[[^\\]]*$)",
    "decreaseIndentPattern": "(?x)\n  (^\\s*</[a-zA-Z][a-zA-Z0-9-]*\\s*>)\n  |(^\\s*/>)\n  |(^\\s*@(endif|endunless|endforeach|endforelse|endfor|endwhile|endswitch|endauth|endguest|endcan|endcannot|endcanany|endsection|endcomponent|endslot|endpush|endprepend|endonce|endphp|endisset|endempty|endenv|endproduction|endverbatim|enderror|endsetup|endregister|endscript|endawait|endblock|endcomment|else|elseif|case|default|break|empty)\\b)\n  |(^\\s*[}\\]])"
  },
  "onEnterRules": [
    {
      "beforeText": "<(?!(?:area|base|br|col|embed|hr|img|input|keygen|link|menuitem|meta|param|source|track|wbr)\\b)([a-zA-Z][a-zA-Z0-9-]*)\\b[^/>]*>\\s*$",
      "afterText": "^\\s*</\\1\\s*>",
      "action": {
        "indent": "indentOutdent",
        "appendText": "\t"
      }
    },
    {
      "beforeText": "<(?!(?:area|base|br|col|embed|hr|img|input|keygen|link|menuitem|meta|param|source|track|wbr)\\b)([a-zA-Z][a-zA-Z0-9-]*)\\b[^/>]*>\\s*$",
      "action": {
        "indent": "indent"
      }
    },
    {
      "beforeText": "^\\s*@(if|unless|foreach|forelse|for|while|switch|auth|guest|can|cannot|canany|section|component|slot|push|prepend|once|php|isset|empty|env|production|verbatim|error|setup|register|script|await|block|comment)\\b.*$",
      "action": {
        "indent": "indent"
      }
    },
    {
      "beforeText": "^\\s*@(else|elseif|case|default|empty)\\b.*$",
      "action": {
        "indent": "indent"
      }
    },
    {
      "beforeText": "^\\s*@(endif|endunless|endforeach|endforelse|endfor|endwhile|endswitch|endauth|endguest|endcan|endcannot|endcanany|endsection|endcomponent|endslot|endpush|endprepend|endonce|endphp|endisset|endempty|endenv|endproduction|endverbatim|enderror|endsetup|endregister|endscript|endawait|endblock|endcomment)\\b",
      "action": {
        "indent": "none"
      }
    },
    {
      "beforeText": "\\{\\s*$",
      "afterText": "^\\s*\\}",
      "action": {
        "indent": "indentOutdent",
        "appendText": "\t"
      }
    },
    {
      "beforeText": "\\{\\s*$",
      "action": {
        "indent": "indent"
      }
    },
    {
      "beforeText": "^\\s*/>\\s*$",
      "action": {
        "indent": "none"
      }
    }
  ],
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\$\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)"
}
