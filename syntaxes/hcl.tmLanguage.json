{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HCL Template",
  "scopeName": "text.html.hcl",
  "fileTypes": ["hcl"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#blocks"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.hcl",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.hcl",
          "match": "//.*$"
        },
        {
          "name": "comment.block.hcl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.hcl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.hcl",
              "match": "\\\\."
            },
            {
              "name": "variable.interpolation.hcl",
              "match": "\\$\\{[^}]+\\}"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hcl",
          "match": "\\b(\\d+\\.?\\d*|0x[0-9a-fA-F]+)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.hcl",
          "match": "\\b(for|if|else|variable|locals|output|resource|data|module|terraform|provider|backend|dynamic|condition)\\b"
        },
        {
          "name": "constant.language.hcl",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "variable.other.property.hcl",
          "match": "([a-zA-Z_][a-zA-Z0-9_-]*)(?=\\s*=)"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.hcl",
          "match": "(=|==|!=|<|>|<=|>=|&&|\\|\\||!|\\+|-|\\*|/|%)"
        }
      ]
    },
    "blocks": {
      "patterns": [
        {
          "name": "storage.type.hcl",
          "match": "\\b(resource|data|module|variable|output|locals|terraform|provider|backend)\\b"
        }
      ]
    }
  }
}
