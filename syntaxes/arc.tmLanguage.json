{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ARC Template",
  "scopeName": "text.html.arc",
  "fileTypes": ["arc"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#directives"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.arc",
          "match": "//.*$"
        },
        {
          "name": "comment.line.number-sign.arc",
          "match": "#.*$"
        },
        {
          "name": "comment.block.arc",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.arc",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.arc",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.arc",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.arc",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.arc",
          "match": "\\b(\\d+\\.?\\d*|0x[0-9a-fA-F]+)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.arc",
          "match": "\\b(if|then|else|loop|while|do|end|def|class|object|trait|type|match|case)\\b"
        },
        {
          "name": "constant.language.arc",
          "match": "\\b(true|false|nil|None)\\b"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "keyword.control.directive.arc",
          "match": "(@[a-zA-Z_]\\w*)"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.arc",
          "match": "\\{[^}]+\\}"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arc",
          "match": "(\\+|-|\\*|/|%|==|!=|<|>|<=|>=|&&|\\|\\||!|:=|->)"
        }
      ]
    }
  }
}
