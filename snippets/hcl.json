{
  "HCL Resource": {
    "prefix": "hcl:resource",
    "body": [
      "resource \"${1:type}\" \"${2:name}\" {",
      "\t$3",
      "}"
    ],
    "description": "HCL resource block"
  },
  "HCL Data Source": {
    "prefix": "hcl:data",
    "body": [
      "data \"${1:type}\" \"${2:name}\" {",
      "\t$3",
      "}"
    ],
    "description": "HCL data source block"
  },
  "HCL Variable": {
    "prefix": "hcl:variable",
    "body": [
      "variable \"${1:name}\" {",
      "\ttype = ${2:string}",
      "\tdescription = \"${3:description}\"",
      "\t$4",
      "}"
    ],
    "description": "HCL variable declaration"
  },
  "HCL Output": {
    "prefix": "hcl:output",
    "body": [
      "output \"${1:name}\" {",
      "\tvalue = ${2:value}",
      "\tdescription = \"${3:description}\"",
      "}"
    ],
    "description": "HCL output block"
  },
  "HCL Module": {
    "prefix": "hcl:module",
    "body": [
      "module \"${1:name}\" {",
      "\tsource = \"${2:source}\"",
      "\t$3",
      "}"
    ],
    "description": "HCL module block"
  },
  "HCL Provider": {
    "prefix": "hcl:provider",
    "body": [
      "provider \"${1:type}\" {",
      "\t$2",
      "}"
    ],
    "description": "HCL provider block"
  },
  "HCL Locals": {
    "prefix": "hcl:locals",
    "body": [
      "locals {",
      "\t${1:key} = ${2:value}",
      "}"
    ],
    "description": "HCL locals block"
  },
  "HCL For Each": {
    "prefix": "hcl:for-each",
    "body": [
      "for_each = ${1:var.items}",
      "$2"
    ],
    "description": "HCL for_each loop"
  },
  "HCL Count": {
    "prefix": "hcl:count",
    "body": [
      "count = ${1:var.count}"
    ],
    "description": "HCL count meta-argument"
  },
  "HCL If Condition": {
    "prefix": "hcl:if",
    "body": [
      "${1:resource} = ${2:condition} ? ${3:true_value} : ${4:false_value}"
    ],
    "description": "HCL conditional expression"
  }
}
