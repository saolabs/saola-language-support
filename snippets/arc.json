{
  "ARC If Statement": {
    "prefix": "arc:if",
    "body": [
      "if ${1:condition} then",
      "\t$2",
      "end"
    ],
    "description": "ARC if statement"
  },
  "ARC If-Then-Else": {
    "prefix": "arc:if-else",
    "body": [
      "if ${1:condition} then",
      "\t$2",
      "else",
      "\t$3",
      "end"
    ],
    "description": "ARC if-then-else statement"
  },
  "ARC Loop": {
    "prefix": "arc:loop",
    "body": [
      "loop ${1:variable} in ${2:collection}",
      "\t$3",
      "end"
    ],
    "description": "ARC loop statement"
  },
  "ARC While Loop": {
    "prefix": "arc:while",
    "body": [
      "while ${1:condition}",
      "\t$2",
      "end"
    ],
    "description": "ARC while loop"
  },
  "ARC Definition": {
    "prefix": "arc:def",
    "body": [
      "def ${1:name}(${2:params})",
      "\t$3",
      "end"
    ],
    "description": "ARC function definition"
  },
  "ARC Class": {
    "prefix": "arc:class",
    "body": [
      "class ${1:ClassName}",
      "\t$2",
      "end"
    ],
    "description": "ARC class definition"
  },
  "ARC Trait": {
    "prefix": "arc:trait",
    "body": [
      "trait ${1:TraitName}",
      "\t$2",
      "end"
    ],
    "description": "ARC trait definition"
  },
  "ARC Match": {
    "prefix": "arc:match",
    "body": [
      "match ${1:value}",
      "\tcase ${2:pattern} -> ${3:result}",
      "\tcase _ -> ${4:default}",
      "end"
    ],
    "description": "ARC match expression"
  },
  "ARC Type": {
    "prefix": "arc:type",
    "body": [
      "type ${1:TypeName} = ${2:definition}"
    ],
    "description": "ARC type declaration"
  },
  "ARC Directive": {
    "prefix": "arc:directive",
    "body": [
      "@${1:directiveName}${2:(${3:params})}"
    ],
    "description": "ARC directive"
  },
  "ARC Comment": {
    "prefix": "arc:comment",
    "body": [
      "// ${1:comment}"
    ],
    "description": "ARC single line comment"
  },
  "ARC Block Comment": {
    "prefix": "arc:block-comment",
    "body": [
      "/*",
      " * ${1:comment}",
      " */"
    ],
    "description": "ARC block comment"
  }
}
